---
import Base from '../layouts/Base.astro';
import daten from '../data/paritaet-2050.de.json';

const { meta, ausgangslage, doktrin, fahrplan, hebel, machtkarte, regionen, netzwerke, organisationen, beweislage, softpower, huerden, scheitern, quellen } = daten;

// Abschnitte nummerieren sich selbst, damit neue Abschnitte keine Handarbeit erzwingen
const ROMAN = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV'];
let secCount = 0;
const sec = () => `(${ROMAN[secCount++]})`;

const catById = Object.fromEntries(hebel.kategorien.map((k) => [k.id, k]));
const tempo = ausgangslage.tempo;
const tempoCfg = {
  basisWert: tempo.basisWert,
  basisJahr: tempo.basisJahr,
  jahre: tempo.jahreBisParitaet,
  min: tempo.minJahr,
  max: tempo.maxJahr,
};
---

<Base title={meta.titel} description={meta.description} lang="de" noindex={true}>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="shell hero-shell">
      <p class="kicker" data-reveal><span class="dot" aria-hidden="true"></span> {meta.kicker}</p>
      <h1 class="display hero-title" data-reveal>{meta.titel}</h1>
      <div class="hero-foot" data-reveal style="--delay:180ms">
        <p class="lede">{meta.untertitel}</p>
        <p class="hero-cite">{meta.stand}</p>
      </div>
    </div>
    <div class="hero-line" aria-hidden="true"></div>
  </section>

  <!-- ===================== I. AUSGANGSLAGE ===================== -->
  <section class="section" id="ausgangslage">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{ausgangslage.label}</span>
      </div>
      <p class="lead-in" data-reveal>{ausgangslage.lead}</p>

      <div class="kpi-grid">
        {ausgangslage.kennzahlen.map((k, i) => (
          <div class="kpi" data-reveal style={`--delay:${i * 80}ms`}>
            <div class="kpi-num" data-viz="counter">
              <span
                class="counter-num"
                data-count={k.wert}
                data-suffix={k.suffix}
                data-decimals={k.dezimalen}
              >0</span>
            </div>
            <p class="kpi-label">{k.label}</p>
            <p class="kpi-src">{k.fussnote}</p>
          </div>
        ))}
      </div>

      <p class="kernsatz" data-reveal>{ausgangslage.kernsatz}</p>

      <!-- Subindizes -->
      <div class="block" data-reveal>
        <h3 class="block-title">{ausgangslage.subindizes.titel}</h3>
        <p class="block-note">{ausgangslage.subindizes.hinweis}</p>
        <div class="bars" data-viz="bars">
          {ausgangslage.subindizes.items.map((s) => (
            <div class="bar-row">
              <span class="bar-label">{s.name}</span>
              <div class="bar-track">
                <div class="bar-fill" style={`--w:${s.wert}%`}></div>
              </div>
              <span class="bar-val">{s.wert.toFixed(1).replace('.', ',')} %</span>
              <span class="bar-side">{s.notiz}</span>
            </div>
          ))}
        </div>
        <p class="block-src">{ausgangslage.subindizes.quelle}</p>
        <p class="block-schluss">{ausgangslage.subindizes.schluss}</p>
      </div>

      <!-- Tempo-Rechner -->
      <div class="tempo" data-reveal id="tempo">
        <h3 class="block-title">{tempo.titel}</h3>
        <p class="block-note">{tempo.lead}</p>
        <div class="tempo-control">
          <label class="tempo-lab" for="ziel">Zieljahr</label>
          <input
            id="ziel"
            class="slider"
            type="range"
            min={tempo.minJahr}
            max={tempo.maxJahr}
            step="1"
            value={tempo.startJahr}
          />
          <output class="tempo-jahr" id="tempoJahr">{tempo.startJahr}</output>
        </div>
        <div class="tempo-out">
          <div class="tempo-cell">
            <span class="tempo-big" id="tempoFaktor">5,1</span>
            <span class="tempo-cap">mal so schnell wie heute</span>
          </div>
          <div class="tempo-cell">
            <span class="tempo-mid" id="tempoRate">1,30</span>
            <span class="tempo-cap">Prozentpunkte pro Jahr nötig</span>
          </div>
          <div class="tempo-cell">
            <span class="tempo-mid tempo-ist">0,25</span>
            <span class="tempo-cap">Prozentpunkte pro Jahr tatsächlich</span>
          </div>
        </div>
        <p class="block-src">{tempo.fussnote}</p>
        <p class="block-schluss">{tempo.schluss}</p>
      </div>

      <!-- Rückschritt -->
      <div class="block warn" data-reveal>
        <h3 class="block-title">{ausgangslage.rueckschritt.titel}</h3>
        <ul class="ticks">
          {ausgangslage.rueckschritt.punkte.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== II. DOKTRIN ===================== -->
  <section class="section" id="doktrin">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{doktrin.label}</span>
      </div>
      <p class="lead-in" data-reveal>{doktrin.lead}</p>

      <div class="dok-list">
        {doktrin.punkte.map((p, i) => (
          <article class="dok" data-reveal style={`--delay:${(i % 2) * 70}ms`}>
            <span class="dok-n">{p.n}</span>
            <div class="dok-body">
              <h3 class="dok-title">{p.titel}</h3>
              <p class="dok-satz">{p.satz}</p>
              <p class="dok-text">{p.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== III. FAHRPLAN ===================== -->
  <section class="section" id="fahrplan">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{fahrplan.label}</span>
      </div>
      <p class="lead-in" data-reveal>{fahrplan.lead}</p>

      <div class="ph-tabs" role="tablist" aria-label={fahrplan.label} data-reveal>
        {fahrplan.phasen.map((ph, i) => (
          <button
            class={`ph-tab${i === 0 ? ' is-active' : ''}`}
            data-phase={ph.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            <span class="ph-num">{ph.num}</span>
            <span class="ph-t">{ph.titel}</span>
            <span class="ph-z">{ph.zeitraum}</span>
          </button>
        ))}
      </div>

      {fahrplan.phasen.map((ph, i) => (
        <div class={`ph-panel${i === 0 ? ' is-active' : ''}`} id={`panel-${ph.id}`} hidden={i !== 0}>
          <p class="ph-these">{ph.these}</p>

          <div class="ph-cols">
            <div class="ph-col">
              <h4 class="mini-h">Ziele</h4>
              <ul class="ticks">
                {ph.ziele.map((z) => <li>{z}</li>)}
              </ul>
            </div>
            <div class="ph-col ph-col-wide">
              <h4 class="mini-h">Instrumente</h4>
              <dl class="instr">
                {ph.instrumente.map((it) => (
                  <div class="instr-row">
                    <dt>{it.name}</dt>
                    <dd>{it.was}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </div>

          <div class="ph-foot">
            <div class="ph-mile">
              <span class="mini-lab">Meilenstein</span>
              <p>{ph.meilenstein}</p>
            </div>
            <div class="ph-risk">
              <span class="mini-lab">Risiko</span>
              <p>{ph.risiko}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== IV. HEBEL ===================== -->
  <section class="section" id="hebel">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{hebel.label} · {hebel.items.length} Instrumente</span>
      </div>
      <p class="lead-in" data-reveal>{hebel.lead}</p>

      <div class="filters" data-reveal>
        <button class="chip is-active" data-filter="alle" aria-pressed="true">Alle</button>
        {hebel.kategorien.map((k) => (
          <button class="chip" data-filter={k.id} aria-pressed="false" style={`--cat:${k.farbe}`}>
            <span class="chip-dot" aria-hidden="true"></span>{k.name}
          </button>
        ))}
      </div>

      <div class="hebel-grid">
        {hebel.items.map((h, i) => {
          const cat = catById[h.kategorie];
          return (
            <article
              class="lever"
              data-category={h.kategorie}
              data-reveal
              style={`--delay:${(i % 3) * 70}ms; --cat:${cat.farbe}`}
            >
              <span class="lever-cat"><span class="chip-dot" aria-hidden="true"></span>{cat.name}</span>
              <h3 class="lever-name">{h.name}</h3>
              <p class="lever-base">{h.grundlage}</p>

              <div class="meters" data-viz="bars">
                <div class="meter">
                  <span class="meter-l">{hebel.skalen.reichweite}</span>
                  <div class="meter-track"><div class="meter-fill" style={`--w:${h.reichweite}%`}></div></div>
                </div>
                <div class="meter">
                  <span class="meter-l">{hebel.skalen.kraft}</span>
                  <div class="meter-track"><div class="meter-fill" style={`--w:${h.kraft}%`}></div></div>
                </div>
                <div class="meter">
                  <span class="meter-l">{hebel.skalen.widerstand}</span>
                  <div class="meter-track"><div class="meter-fill is-warn" style={`--w:${h.widerstand}%`}></div></div>
                </div>
              </div>

              <p class="lever-mech">{h.mechanik}</p>
              <p class="lever-note">{h.notiz}</p>
            </article>
          );
        })}
      </div>
      <p class="empty" id="empty" hidden>Keine Instrumente in dieser Kategorie.</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== V. MACHTKARTE ===================== -->
  <section class="section" id="machtkarte">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{machtkarte.label}</span>
      </div>
      <p class="lead-in" data-reveal>{machtkarte.lead}</p>
      <p class="kernsatz" data-reveal>{machtkarte.kernsatz}</p>
      <p class="vorbem" data-reveal>{machtkarte.vorbemerkung}</p>

      <!-- Engpässe -->
      <div class="mk-head" data-reveal>
        <h3 class="block-title">{machtkarte.engpaesse.titel}</h3>
        <p class="block-note">{machtkarte.engpaesse.lead}</p>
      </div>

      <div class="choke-list">
        {machtkarte.engpaesse.items.map((c, i) => (
          <details class="choke" data-reveal style={`--delay:${(i % 3) * 50}ms`} open={i === 0}>
            <summary>
              <span class="choke-rank">{String(i + 1).padStart(2, '0')}</span>
              <span class="choke-main">
                <span class="choke-name">{c.name}</span>
                <span class="choke-ctrl">{c.kontrolliert}</span>
              </span>
              <span class="choke-ebene">{c.ebene}</span>
              <span class="choke-meters" aria-hidden="true">
                <span class="cm"><span class="cm-l">H</span><span class="cm-t"><span class="cm-f" style={`--w:${c.hebel}%`}></span></span></span>
                <span class="cm"><span class="cm-l">U</span><span class="cm-t"><span class="cm-f is-alt" style={`--w:${c.umgehbar}%`}></span></span></span>
                <span class="cm"><span class="cm-l">Z</span><span class="cm-t"><span class="cm-f is-alt" style={`--w:${c.zugang}%`}></span></span></span>
              </span>
            </summary>
            <div class="choke-body">
              <p class="choke-why">{c.warum}</p>
              <div class="choke-in">
                <span class="mini-lab">Weg dorthin</span>
                <p>{c.wegHinein}</p>
              </div>
              <p class="choke-note">{c.notiz}</p>
              <p class="choke-src">{c.quelle}</p>
            </div>
          </details>
        ))}
      </div>
      <p class="legend" data-reveal>
        <span>H {machtkarte.engpaesse.skalen.hebel}</span>
        <span>U {machtkarte.engpaesse.skalen.umgehbar}</span>
        <span>Z {machtkarte.engpaesse.skalen.zugang}</span>
      </p>

      <!-- Laufbahnen -->
      <div class="block" data-reveal>
        <h3 class="block-title">{machtkarte.laufbahnen.titel}</h3>
        <p class="block-note">{machtkarte.laufbahnen.lead}</p>
        <div class="paths">
          {machtkarte.laufbahnen.wege.map((w) => (
            <article class="path">
              <h4 class="path-name">{w.name}</h4>
              <p class="path-proc">{w.verfahren}</p>
              <p class="path-meta"><span>{w.dauer}</span><span>{w.huerde}</span></p>
              <p class="path-note">{w.notiz}</p>
            </article>
          ))}
        </div>
        <p class="block-schluss">{machtkarte.laufbahnen.befund}</p>
      </div>

      <!-- Zugang von außen -->
      <div class="block" data-reveal>
        <h3 class="block-title">{machtkarte.zugang.titel}</h3>
        <p class="block-note">{machtkarte.zugang.lead}</p>
        <div class="ev-list">
          {machtkarte.zugang.kanaele.map((k) => (
            <article class="ev">
              <p class="ev-befund">{k.name}</p>
              <p class="ev-was">{k.was}</p>
              <p class="ev-was ev-eff">{k.wirkung}</p>
            </article>
          ))}
        </div>
        <p class="block-schluss">{machtkarte.zugang.vorbehalt}</p>
      </div>

      <!-- Irrtum -->
      <div class="block warn" data-reveal>
        <h3 class="block-title">{machtkarte.irrtum.titel}</h3>
        <ul class="ticks">
          {machtkarte.irrtum.punkte.map((p) => <li>{p}</li>)}
        </ul>
        <p class="block-src">{machtkarte.irrtum.quelle}</p>
      </div>

      <!-- Minimalbesetzung -->
      <div class="minmax" data-reveal>
        <h3 class="block-title">{machtkarte.minimum.titel}</h3>
        <p class="block-note">{machtkarte.minimum.lead}</p>

        <div class="crew">
          <div class="crew-col">
            <div class="crew-head">
              <span class="crew-n">{machtkarte.minimum.kern.length}</span>
              <span class="crew-t">{machtkarte.minimum.kernTitel}</span>
            </div>
            <ol class="crew-list">
              {machtkarte.minimum.kern.map((r) => (
                <li><span class="crew-r">{r.rolle}</span><span class="crew-w">{r.warum}</span><span class="crew-p">{r.profil}</span><span class="crew-way">{r.weg}</span></li>
              ))}
            </ol>
          </div>
          <div class="crew-col crew-soft">
            <div class="crew-head">
              <span class="crew-n">{machtkarte.minimum.erweiterung.length}</span>
              <span class="crew-t">{machtkarte.minimum.erweiterungTitel}</span>
            </div>
            <ol class="crew-list">
              {machtkarte.minimum.erweiterung.map((r) => (
                <li><span class="crew-r">{r.rolle}</span><span class="crew-w">{r.warum}</span><span class="crew-p">{r.profil}</span><span class="crew-way">{r.weg}</span></li>
              ))}
            </ol>
          </div>
        </div>
        <p class="vorbem">{machtkarte.minimum.profilHinweis}</p>

        <div class="crew-schluss">
          {machtkarte.minimum.schluss.map((s) => <p>{s}</p>)}
        </div>
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== REGIONEN ===================== -->
  <section class="section" id="regionen">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{regionen.label}</span>
      </div>
      <p class="lead-in" data-reveal>{regionen.lead}</p>
      <p class="kernsatz" data-reveal>{regionen.kernsatz}</p>

      <!-- Die Umkehrung -->
      <div class="block warn" data-reveal>
        <h3 class="block-title">{regionen.umkehrung.titel}</h3>
        <p class="block-note">{regionen.umkehrung.lead}</p>
        <ul class="ticks">
          {regionen.umkehrung.punkte.map((p) => <li>{p}</li>)}
        </ul>
        <p class="block-schluss">{regionen.umkehrung.folgerung}</p>
      </div>

      <!-- Tempo je Region -->
      <div class="block" data-reveal>
        <h3 class="block-title">{regionen.tempo.titel}</h3>
        <p class="block-note">{regionen.tempo.hinweis}</p>
        <div class="rtempo" data-viz="bars">
          {regionen.tempo.items.map((r) => (
            <div class="rt-row">
              <span class="rt-name">{r.name}</span>
              <div class="rt-track">
                <div class="rt-fill" style={`--w:${Math.round((r.jahre / 208) * 100)}%`}></div>
              </div>
              <span class="rt-j">{r.jahre} J.</span>
              <span class="rt-s">{r.score.toFixed(1).replace('.', ',')} %</span>
              <span class="rt-d">+{r.seit.toFixed(1).replace('.', ',')} Pp seit 2006</span>
            </div>
          ))}
        </div>
        <p class="block-src">{regionen.tempo.quelle}</p>
        <p class="block-schluss">{regionen.tempo.schluss}</p>
      </div>

      <!-- Regionen einzeln -->
      <div class="reg-list">
        {regionen.items.map((r, i) => (
          <details class="reg" data-reveal style={`--delay:${(i % 3) * 50}ms`} open={i === 0}>
            <summary>
              <span class="reg-main">
                <span class="reg-name">{r.name}</span>
                <span class="reg-top">{r.spitze}</span>
              </span>
              <span class="reg-j">{r.jahre}<span class="reg-ju">Jahre</span></span>
            </summary>
            <div class="reg-body">
              <p class="reg-profil">{r.profil}</p>
              <div class="reg-cols">
                <div class="reg-col">
                  <span class="mini-lab">Schwachstelle</span>
                  <p>{r.schwaeche}</p>
                </div>
                <div class="reg-col">
                  <span class="mini-lab">Regionales Instrument</span>
                  <p class="reg-instr">{r.instrument}</p>
                  <p>{r.instrumentStand}</p>
                </div>
              </div>
              <div class="reg-ansatz">
                <span class="mini-lab">Ansatz</span>
                <p>{r.ansatz}</p>
              </div>
            </div>
          </details>
        ))}
      </div>

      <!-- Reformer -->
      <div class="block" data-reveal>
        <h3 class="block-title">{regionen.reformer.titel}</h3>
        <p class="block-note">{regionen.reformer.text}</p>
        <div class="reformers">
          {regionen.reformer.laender.map((l) => <span class="reformer">{l}</span>)}
        </div>
        <p class="block-schluss">{regionen.reformer.schluss}</p>
        <p class="block-src">{regionen.reformer.quelle}</p>
      </div>

      <p class="vorbem" data-reveal>{regionen.methodik}</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== NETZWERKE ===================== -->
  <section class="section" id="netzwerke">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{netzwerke.label}</span>
      </div>
      <p class="lead-in" data-reveal>{netzwerke.lead}</p>
      <p class="kernsatz" data-reveal>{netzwerke.kernsatz}</p>

      {netzwerke.ebenen.map((e) => (
        <div class="nw-ebene" data-reveal>
          <h3 class="nw-ebene-t">{e.name}</h3>
          <div class="nw-grid">
            {e.items.map((o) => (
              <article class="nw">
                <div class="nw-head">
                  <h4 class="nw-name">{o.name}</h4>
                  {o.gegruendet && <span class="nw-jahr">{o.gegruendet}</span>}
                </div>
                <p class="nw-reach">{o.reichweite}</p>
                <p class="nw-focus">{o.schwerpunkt}</p>
                <p class="nw-eff">{o.wirkung}</p>
                <p class="nw-acc"><span class="mini-lab">Zugang</span>{o.zugang}</p>
                {o.notiz && <p class="nw-note">{o.notiz}</p>}
                <a class="nw-url" href={o.url} target="_blank" rel="noopener">{o.url.replace('https://', '').replace(/\/$/, '')}</a>
              </article>
            ))}
          </div>
        </div>
      ))}

      <!-- Rangliste -->
      <div class="block" data-reveal>
        <h3 class="block-title">{netzwerke.rangliste.titel}</h3>
        <p class="block-note">{netzwerke.rangliste.lead}</p>
        <ol class="nwrank">
          {netzwerke.rangliste.items.map((r) => (
            <li><span class="nwrank-n">{r.n}</span><span class="nwrank-b"><span class="nwrank-name">{r.name}</span><span class="nwrank-w">{r.warum}</span></span></li>
          ))}
        </ol>
      </div>

      <!-- Missverhältnis -->
      <div class="block warn" data-reveal>
        <h3 class="block-title">{netzwerke.luecke.titel}</h3>
        <p class="block-note">{netzwerke.luecke.text}</p>
        <p class="block-schluss">{netzwerke.luecke.folgerung}</p>
      </div>

      <p class="vorbem" data-reveal>{netzwerke.vorbehalt}</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== ORGANISATIONEN ===================== -->
  <section class="section" id="organisationen">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{organisationen.label}</span>
      </div>
      <p class="lead-in" data-reveal>{organisationen.lead}</p>
      <p class="kernsatz" data-reveal>{organisationen.kernsatz}</p>

      <div class="org-list">
        {organisationen.items.map((o, i) => (
          <details class="org" data-reveal style={`--delay:${(i % 3) * 50}ms`} open={i === 0}>
            <summary>
              <span class="org-kurz">{o.kurz}</span>
              <span class="org-main">
                <span class="org-name">{o.name}</span>
                <span class="org-rule">{o.entscheidung}</span>
              </span>
              <span class="org-meter" aria-hidden="true"><span class="org-fill" style={`--w:${o.hebel}%`}></span></span>
            </summary>
            <div class="org-body">
              <div class="org-cols">
                <div class="org-col"><span class="mini-lab">Mandat</span><p>{o.mandat}</p></div>
                <div class="org-col"><span class="mini-lab">Rolle der EU</span><p>{o.euRolle}</p></div>
              </div>
              <div class="org-col"><span class="mini-lab">Was dort besteht</span><p>{o.bestand}</p></div>
              <div class="org-ansatz"><span class="mini-lab">Ansatzpunkt</span><p>{o.ansatz}</p></div>
              <p class="org-note">{o.notiz}</p>
            </div>
          </details>
        ))}
      </div>
      <p class="legend" data-reveal><span>Balken: geschätzte Hebelwirkung für diese Agenda</span></p>

      <!-- ILO-Ratifikationstabelle -->
      <div class="block" data-reveal>
        <h3 class="block-title">{organisationen.ilo.titel}</h3>
        <p class="block-note">{organisationen.ilo.lead}</p>
        <div class="ratif">
          <div class="ratif-head">
            <span>Übereinkommen</span><span>Jahr</span><span>Weltweit</span><span>EU-27</span><span>Deutschland</span>
          </div>
          {organisationen.ilo.items.map((k) => (
            <div class={`ratif-row${k.de ? '' : ' is-gap'}`}>
              <span class="ratif-n"><strong>{k.name}</strong><em>{k.nr} · fehlen unter anderem {k.fehlen}</em></span>
              <span class="ratif-j">{k.jahr}</span>
              <span class="ratif-r">{k.rat}</span>
              <span class={`ratif-eu${k.eu < 20 ? ' is-low' : ''}`}>{k.eu} von 27</span>
              <span class={`ratif-de${k.de ? '' : ' is-no'}`}>{k.de ? 'ja' : 'nein'}</span>
            </div>
          ))}
        </div>
        <ul class="ticks">
          {organisationen.ilo.befund.map((b) => <li>{b}</li>)}
        </ul>
        <p class="block-src">{organisationen.ilo.quelle}</p>
      </div>

      <!-- Geldrichtung -->
      <div class="block warn" data-reveal>
        <h3 class="block-title">{organisationen.geld.titel}</h3>
        <p class="block-note">{organisationen.geld.lead}</p>
        <div class="geld">
          {organisationen.geld.zahlen.map((z) => (
            <div class={`geld-row is-${z.richtung}`}>
              <span class="geld-w">{z.wert}</span>
              <span class="geld-t">{z.was}</span>
            </div>
          ))}
        </div>
        <p class="block-schluss">{organisationen.geld.schluss}</p>
        <p class="block-src">{organisationen.geld.quelle}</p>
      </div>

      <p class="kernsatz" data-reveal>{organisationen.schluss}</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== BEWEISLAGE ===================== -->
  <section class="section" id="beweislage">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{beweislage.label}</span>
      </div>
      <p class="lead-in" data-reveal>{beweislage.lead}</p>

      <div class="cases">
        {beweislage.faelle.map((f, i) => (
          <article class="case" data-reveal style={`--delay:${(i % 2) * 70}ms`}>
            <div class="case-head">
              <div>
                <h3 class="case-name">{f.name}</h3>
                <span class="case-jahr">{f.jahr}</span>
              </div>
              <span class={`case-tag${f.ergebnis.startsWith('gelungen') ? ' ok' : ' warn'}`}>{f.ergebnis}</span>
            </div>
            <div class="case-kpi">
              <span class="case-big">{f.kennzahl}</span>
              <span class="case-cap">{f.kennzahlLabel}</span>
            </div>
            <p class="case-mech">{f.mechanik}</p>
            <p class="case-lehre"><span class="mini-lab">Lehre</span>{f.lehre}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== VII. SOFTPOWER ===================== -->
  <section class="section" id="softpower">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{softpower.label}</span>
      </div>
      <p class="lead-in" data-reveal>{softpower.lead}</p>
      <p class="kernsatz" data-reveal>{softpower.kernsatz}</p>

      <div class="block" data-reveal>
        <h3 class="block-title">{softpower.evidenz.titel}</h3>
        <p class="block-note">{softpower.evidenz.hinweis}</p>
        <div class="ev-list">
          {softpower.evidenz.items.map((e) => (
            <article class="ev">
              <p class="ev-befund">{e.befund}</p>
              <p class="ev-was">{e.was}</p>
              <p class="ev-src">{e.quelle}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="block" data-reveal>
        <h3 class="block-title">{softpower.vergleich.titel}</h3>
        <div class="cmp">
          {softpower.vergleich.zeilen.map((z) => (
            <div class={`cmp-row${z.stark ? ' is-strong' : ''}`}>
              <span class="cmp-l">{z.label}</span>
              <span class="cmp-v">{z.wert}</span>
            </div>
          ))}
        </div>
        <p class="block-schluss">{softpower.vergleich.schluss}</p>
      </div>

      <div class="dok-list" data-reveal>
        {softpower.regeln.map((r) => (
          <article class="dok">
            <span class="dok-n">{r.n}</span>
            <div class="dok-body">
              <h3 class="dok-title">{r.titel}</h3>
              <p class="dok-text">{r.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== VIII. HÜRDEN ===================== -->
  <section class="section" id="huerden">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{huerden.label} · {huerden.items.length}</span>
      </div>
      <p class="lead-in" data-reveal>{huerden.lead}</p>

      <div class="veto">
        {huerden.items.map((h, i) => (
          <details class="veto-row" data-reveal style={`--delay:${(i % 3) * 50}ms`} open={i === 0}>
            <summary>
              <span class="veto-title">{h.titel}</span>
              <span class="veto-base">{h.grundlage}</span>
              <span class="veto-meter" aria-hidden="true">
                <span class="veto-fill" style={`--w:${h.haerte}%`}></span>
              </span>
              <span class="veto-h">{h.haerte}</span>
            </summary>
            <div class="veto-body">
              <p class="veto-desc">{h.beschreibung}</p>
              <div class="veto-out">
                <span class="mini-lab">Weg daran vorbei</span>
                <p>{h.umgehung}</p>
              </div>
              <p class="veto-status">Belegstatus: {h.status}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== IX. SCHEITERN ===================== -->
  <section class="section" id="scheitern">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{scheitern.label}</span>
      </div>
      <p class="lead-in" data-reveal>{scheitern.lead}</p>

      <ol class="fails">
        {scheitern.modi.map((m, i) => (
          <li class="fail" data-reveal style={`--delay:${i * 60}ms`}>
            <span class="fail-jahr">{m.jahr}</span>
            <div class="fail-body">
              <h3 class="fail-title">{m.titel}</h3>
              <p>{m.text}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="kernsatz" data-reveal>{scheitern.schluss}</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== X. QUELLEN ===================== -->
  <section class="section note" id="quellen">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">{sec()}</span>
        <span class="sec-label">{quellen.label}</span>
      </div>
      <p class="lead-in" data-reveal>{quellen.lead}</p>

      {quellen.gruppen.map((g) => (
        <div class="qgroup" data-reveal>
          <h3 class="qgroup-t">{g.name}</h3>
          <ul class="qlist">
            {g.items.map((q) => (
              <li>
                <a href={q.url} target="_blank" rel="noopener">{q.titel}</a>
                <span class="qmeta">{q.org}, {q.jahr}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="disclaimer" data-reveal>
        <p>{quellen.vorbehalt}</p>
        <p>{meta.einordnung}</p>
      </div>
    </div>
  </section>

  <script type="application/json" id="tempo-cfg" set:html={JSON.stringify(tempoCfg)} />
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero { padding-block: clamp(3.5rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4.5rem); position: relative; }
  .hero-shell { display: flex; flex-direction: column; gap: clamp(1.75rem, 4vw, 2.75rem); }
  .kicker {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted);
  }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex: none; }
  .hero-title { max-width: 14ch; }
  .hero-foot { display: flex; flex-wrap: wrap; gap: clamp(1.5rem, 5vw, 4rem); align-items: flex-end; justify-content: space-between; }
  .hero-foot .lede { max-width: 46ch; }
  .hero-cite { font-size: 13px; color: var(--faint); letter-spacing: 0.02em; }
  .hero-line { height: 1px; background: var(--hair); margin-top: clamp(2rem, 5vw, 3.5rem); }

  .shell-rule { max-width: var(--maxw); margin-inline: auto; }

  .lead-in { font-size: clamp(1.05rem, 1.9vw, 1.2rem); color: var(--ink-soft); max-width: 60ch; margin-bottom: clamp(2rem, 4vw, 3rem); }

  .kernsatz {
    font-size: clamp(1.4rem, 3.4vw, 2.1rem);
    font-weight: 600; letter-spacing: -0.025em; line-height: 1.2;
    max-width: 24ch; margin-block: clamp(2.5rem, 6vw, 4rem);
    border-left: 2px solid var(--accent); padding-left: clamp(1rem, 2.5vw, 1.75rem);
  }

  /* ---------- KPI ---------- */
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: clamp(1.5rem, 3vw, 2.5rem); }
  .kpi { border-top: 1px solid var(--hair-strong); padding-top: 1.1rem; }
  .kpi-num { font-size: clamp(2.1rem, 5vw, 3.1rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; color: var(--accent); font-variant-numeric: tabular-nums; }
  .kpi-label { font-size: 0.95rem; color: var(--ink-soft); margin-top: 0.7rem; max-width: 30ch; }
  .kpi-src { font-size: 11.5px; color: var(--faint); margin-top: 0.6rem; line-height: 1.45; max-width: 34ch; }

  /* ---------- Blocks ---------- */
  .block { border: 1px solid var(--hair); padding: clamp(1.5rem, 3.5vw, 2.5rem); margin-block: clamp(2rem, 4vw, 3rem); background: color-mix(in srgb, var(--paper-2) 45%, transparent); }
  .block.warn { border-color: color-mix(in srgb, var(--accent) 30%, var(--hair)); }
  .block-title { font-size: 1.15rem; font-weight: 600; letter-spacing: -0.015em; }
  .block-note { font-size: 0.95rem; color: var(--muted); margin-top: 0.5rem; max-width: 58ch; }
  .block-src { font-size: 11.5px; color: var(--faint); margin-top: 1.1rem; max-width: 62ch; }
  .block-schluss { font-size: 1rem; color: var(--ink-soft); margin-top: 1.4rem; padding-top: 1.2rem; border-top: 1px solid var(--hair); max-width: 62ch; }

  /* ---------- Bars ---------- */
  .bars { margin-top: 1.75rem; display: flex; flex-direction: column; gap: 0.9rem; }
  .bar-row { display: grid; grid-template-columns: 11rem 1fr 4.5rem 6rem; gap: 0.9rem; align-items: center; font-size: 0.9rem; }
  .bar-label { color: var(--ink-soft); font-weight: 500; }
  .bar-track { height: 8px; background: var(--hair); position: relative; overflow: hidden; }
  .bar-fill { position: absolute; inset: 0 auto 0 0; width: 0; background: var(--accent); transition: width 1.1s var(--ease); }
  .bars.run .bar-fill { width: var(--w); }
  .bar-val { font-variant-numeric: tabular-nums; color: var(--ink); font-weight: 600; }
  .bar-side { font-size: 12px; color: var(--faint); }

  /* ---------- Tempo ---------- */
  .tempo { border: 1px solid var(--hair-strong); padding: clamp(1.5rem, 3.5vw, 2.5rem); margin-block: clamp(2rem, 4vw, 3rem); }
  .tempo-control { display: flex; align-items: center; gap: 1.25rem; margin-top: 1.75rem; flex-wrap: wrap; }
  .tempo-lab { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); flex: none; }
  .tempo-jahr { font-size: 1.5rem; font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; flex: none; min-width: 4.5ch; }
  .slider { flex: 1 1 220px; -webkit-appearance: none; appearance: none; height: 2px; background: var(--hair-strong); outline: none; }
  .slider::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: var(--accent); cursor: pointer; border: 3px solid var(--paper); box-shadow: 0 0 0 1px var(--hair-strong); }
  .slider::-moz-range-thumb { width: 20px; height: 20px; border-radius: 50%; background: var(--accent); cursor: pointer; border: 3px solid var(--paper); }
  .tempo-out { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .tempo-cell { border-top: 1px solid var(--hair); padding-top: 0.9rem; }
  .tempo-big { display: block; font-size: clamp(2.6rem, 6vw, 3.6rem); font-weight: 700; letter-spacing: -0.045em; line-height: 1; color: var(--accent); font-variant-numeric: tabular-nums; }
  .tempo-mid { display: block; font-size: clamp(1.6rem, 3.5vw, 2.1rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1; font-variant-numeric: tabular-nums; }
  .tempo-ist { color: var(--faint); }
  .tempo-cap { display: block; font-size: 12.5px; color: var(--muted); margin-top: 0.6rem; max-width: 22ch; }

  /* ---------- Listen ---------- */
  .ticks { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.25rem; }
  .ticks li { position: relative; padding-left: 1.3rem; font-size: 0.95rem; color: var(--muted); max-width: 62ch; }
  .ticks li::before { content: ''; position: absolute; left: 0; top: 0.62em; width: 6px; height: 1px; background: var(--accent); }

  /* ---------- Doktrin ---------- */
  .dok-list { display: flex; flex-direction: column; gap: clamp(1.5rem, 3vw, 2.25rem); }
  .dok { display: grid; grid-template-columns: 3.5rem 1fr; gap: clamp(0.75rem, 2vw, 1.75rem); border-top: 1px solid var(--hair); padding-top: 1.5rem; }
  .dok-n { font-size: 0.9rem; color: var(--accent); font-variant-numeric: tabular-nums; letter-spacing: 0.02em; padding-top: 0.25rem; }
  .dok-title { font-size: clamp(1.15rem, 2.4vw, 1.45rem); font-weight: 600; letter-spacing: -0.02em; }
  .dok-satz { font-size: 1.02rem; color: var(--ink-soft); margin-top: 0.55rem; max-width: 56ch; font-weight: 500; }
  .dok-text { font-size: 0.95rem; color: var(--muted); margin-top: 0.85rem; max-width: 66ch; }

  /* ---------- Fahrplan ---------- */
  .ph-tabs { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1px; background: var(--hair); border: 1px solid var(--hair); margin-bottom: clamp(2rem, 4vw, 3rem); }
  .ph-tab { background: var(--paper); border: 0; text-align: left; padding: 1.1rem 1.15rem; cursor: pointer; font: inherit; display: flex; flex-direction: column; gap: 0.3rem; transition: background 0.25s var(--ease); }
  .ph-tab:hover { background: var(--paper-2); }
  .ph-tab.is-active { background: var(--ink); }
  .ph-num { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--accent); }
  .ph-tab.is-active .ph-num { color: var(--paper); opacity: 0.75; }
  .ph-t { font-size: 1rem; font-weight: 600; letter-spacing: -0.015em; color: var(--ink); }
  .ph-tab.is-active .ph-t { color: var(--paper); }
  .ph-z { font-size: 11.5px; color: var(--faint); font-variant-numeric: tabular-nums; }
  .ph-tab.is-active .ph-z { color: color-mix(in srgb, var(--paper) 65%, transparent); }

  .ph-panel[hidden] { display: none; }
  .ph-these { font-size: clamp(1.1rem, 2.2vw, 1.3rem); color: var(--ink-soft); max-width: 60ch; line-height: 1.45; }
  .ph-cols { display: grid; grid-template-columns: 1fr; gap: clamp(1.75rem, 4vw, 3rem); margin-top: clamp(1.75rem, 4vw, 2.75rem); }
  @media (min-width: 860px) { .ph-cols { grid-template-columns: 0.8fr 1.2fr; } }
  .mini-h { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); font-weight: 500; }
  .instr { margin-top: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .instr-row { border-top: 1px solid var(--hair); padding-top: 0.9rem; }
  .instr dt { font-size: 1rem; font-weight: 600; letter-spacing: -0.01em; }
  .instr dd { font-size: 0.93rem; color: var(--muted); margin-top: 0.45rem; max-width: 64ch; }

  .ph-foot { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: clamp(2rem, 4vw, 3rem); }
  @media (min-width: 700px) { .ph-foot { grid-template-columns: 1fr 1fr; } }
  .ph-mile, .ph-risk { border-top: 2px solid var(--ink); padding-top: 0.9rem; }
  .ph-risk { border-top-color: var(--accent); }
  .mini-lab { display: block; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
  .ph-mile p, .ph-risk p { font-size: 0.95rem; color: var(--ink-soft); max-width: 46ch; }

  /* ---------- Filter chips ---------- */
  .filters { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-bottom: clamp(1.75rem, 3vw, 2.5rem); }
  .chip { font: inherit; font-size: 13px; padding: 0.42rem 0.85rem; border: 1px solid var(--hair-strong); background: transparent; border-radius: 100px; cursor: pointer; color: var(--muted); display: inline-flex; align-items: center; gap: 0.45rem; transition: color 0.25s var(--ease), border-color 0.25s var(--ease), background 0.25s var(--ease); }
  .chip:hover { color: var(--ink); border-color: var(--ink); }
  .chip.is-active { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  .chip-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--cat, var(--accent)); flex: none; }

  /* ---------- Hebel ---------- */
  .hebel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--hair); border: 1px solid var(--hair); }
  .lever { background: var(--paper); padding: clamp(1.25rem, 2.5vw, 1.75rem); display: flex; flex-direction: column; gap: 0.65rem; }
  .lever.is-hidden { display: none; }
  .lever-cat { display: inline-flex; align-items: center; gap: 0.45rem; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .lever-name { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.02em; }
  .lever-base { font-size: 12px; color: var(--faint); }
  .meters { display: flex; flex-direction: column; gap: 0.5rem; margin-block: 0.65rem; }
  .meter { display: grid; grid-template-columns: 8.5rem 1fr; gap: 0.7rem; align-items: center; }
  .meter-l { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint); }
  .meter-track { height: 5px; background: var(--hair); position: relative; overflow: hidden; }
  .meter-fill { position: absolute; inset: 0 auto 0 0; width: 0; background: var(--cat, var(--accent)); transition: width 1s var(--ease); }
  .meter-fill.is-warn { background: var(--hair-strong); }
  .meters.run .meter-fill { width: var(--w); }
  .lever-mech { font-size: 0.9rem; color: var(--muted); }
  .lever-note { font-size: 0.87rem; color: var(--ink-soft); border-top: 1px solid var(--hair); padding-top: 0.7rem; margin-top: auto; }
  .empty { margin-top: 2rem; color: var(--muted); font-size: 0.95rem; }

  /* ---------- Machtkarte ---------- */
  .vorbem {
    font-size: 0.95rem; color: var(--muted); max-width: 64ch;
    border-left: 1px solid var(--hair-strong); padding-left: 1.1rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .mk-head { margin-bottom: 1.75rem; }

  .choke-list { border-top: 1px solid var(--hair-strong); }
  .choke { border-bottom: 1px solid var(--hair); }
  .choke summary {
    list-style: none; cursor: pointer; padding: 1.15rem 0;
    display: grid; grid-template-columns: 2.25rem 1fr; gap: 0.4rem 1rem; align-items: start;
  }
