---
const year = 2026;
---

<footer class="foot">
  <hr class="rule" />
  <div class="shell foot-inner">
    <div class="foot-brand">
      <span class="foot-name">Benjamin Balde</span>
      <span class="foot-tag">Strategie &amp; Beratung</span>
    </div>
    <nav class="foot-nav" aria-label="Fußzeile">
      <a href="mailto:balde@geomesh.de">E-Mail</a>
      <a href="https://www.linkedin.com/in/amir-benjamin-balde/" target="_blank" rel="noopener">LinkedIn</a>
    </nav>
    <div class="foot-legal">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
      <span class="foot-c">© {year}</span>
    </div>
  </div>
</footer>

<style>
  .foot { margin-top: auto; }
  .foot-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem 3rem;
    padding-block: clamp(3rem, 6vw, 4.5rem);
    align-items: start;
  }
  .foot-brand { display: flex; flex-direction: column; gap: 0.35rem; }
  .foot-name { font-size: 1.15rem; font-weight: 600; letter-spacing: -0.01em; }
  .foot-tag { font-size: 13px; color: var(--muted); letter-spacing: 0.02em; }
  .foot-nav { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-end; }
  .foot-nav a {
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.25s var(--ease);
  }
  .foot-nav a:hover { color: var(--ink); }
  .foot-legal {
    grid-column: 1 / -1;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding-top: 1.75rem;
    border-top: 1px solid var(--hair);
    font-size: 12px;
    color: var(--faint);
  }
  .foot-legal a { color: var(--faint); text-decoration: none; transition: color 0.25s var(--ease); }
  .foot-legal a:hover { color: var(--ink); }
  .foot-c { margin-left: auto; font-variant-numeric: tabular-nums; }

  @media (max-width: 540px) {
    .foot-inner { grid-template-columns: 1fr; }
    .foot-nav { flex-direction: row; flex-wrap: wrap; align-items: flex-start; gap: 1rem; }
    .foot-legal { flex-wrap: wrap; gap: 1rem; }
    .foot-c { margin-left: 0; width: 100%; }
  }
</style>
