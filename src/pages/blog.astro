---
import Base from '../layouts/Base.astro';
---

<Base title="Blog" description="Der Blog von Benjamin Balde. Bald verfügbar.">
  <section class="journal">
    <div class="shell journal-shell">
      <p class="sec-label" data-reveal>Blog</p>

      <h1 class="display j-title" data-reveal style="--delay:80ms">
        Bald<br /><em>verfügbar.</em>
      </h1>

      <p class="lede j-lede" data-reveal style="--delay:200ms">
        Notizen und Gedanken.
      </p>

      <div class="j-meta" data-reveal style="--delay:320ms">
        <span class="j-dot" aria-hidden="true"></span>
        <span>In Vorbereitung</span>
      </div>

      <div class="j-back" data-reveal style="--delay:420ms">
        <a href="/" class="link"><span class="arrow back" aria-hidden="true">←</span> Zurück</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .journal {
    min-height: calc(100svh - 68px);
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 10vw, 7rem);
  }
  .journal-shell { width: 100%; }
  .sec-label { font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); }
  .j-title { margin: 1.25rem 0 1.75rem; }
  .j-title em { font-style: italic; }
  .j-lede { max-width: 34ch; }
  .j-meta {
    margin-top: 2.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.7em;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .j-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--faint);
    animation: blink 2.4s infinite ease-in-out;
  }
  @keyframes blink { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
  .j-back { margin-top: clamp(3rem, 8vw, 5rem); }
  .arrow.back { display: inline-block; }
  .link:hover .arrow.back { transform: translateX(-3px); }
</style>
