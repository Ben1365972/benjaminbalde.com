---
import Base from '../layouts/Base.astro';

// Persönliches Inhaltsverzeichnis aller Oberflächen. Bewusst versteckt:
// unerratbare URL, noindex, aus dem Sitemap ausgeschlossen (astro.config.mjs).
type Status = 'live' | 'hidden' | 'sandbox';

interface Entry {
  n: string;
  title: string;
  url: string;
  href: string;
  status: Status;
  langs?: string;
  desc: string;
  note?: string;
  links?: { label: string; href: string }[];
}

const statusLabel: Record<Status, string> = {
  live: 'Öffentlich',
  hidden: 'Versteckt',
  sandbox: 'Sandbox',
};

const entries: Entry[] = [
  {
    n: '01',
    title: 'Hauptseite',
    url: 'benjaminbalde.com',
    href: 'https://benjaminbalde.com/',
    status: 'live',
    langs: 'DE · EN',
    desc: 'Die Startseite. Strategische Beratung, Haltung, Schwerpunkte, Leistungen und Kontakt. Zweisprachig, editorial, ohne Framework gebaut.',
    links: [
      { label: 'English', href: 'https://benjaminbalde.com/en/' },
      { label: 'Impressum', href: 'https://benjaminbalde.com/impressum' },
      { label: 'Datenschutz', href: 'https://benjaminbalde.com/datenschutz' },
    ],
  },
  {
    n: '02',
    title: 'Unsichtbare Frauen',
    url: 'benjaminbalde.com/unsichtbare-frauen',
    href: 'https://benjaminbalde.com/unsichtbare-frauen',
    status: 'live',
    langs: 'DE · EN',
    desc: 'Interaktive Datenvisualisierung nach Caroline Criado Perez. 23 belegte Statistiken zur Datenlücke zwischen den Geschlechtern, mit Crashtest-Scrollytelling, Schätz-Slidern und animierten Diagrammen.',
    links: [{ label: 'English', href: 'https://benjaminbalde.com/en/unsichtbare-frauen' }],
  },
  {
    n: '03',
    title: 'Parität 2050',
    url: 'benjaminbalde.com/p2050-…',
    href: 'https://benjaminbalde.com/p2050-godmtztq3lmi3n',
    status: 'hidden',
    langs: 'Nur DE',
    desc: 'Langseite im Stil eines Regierungsdokuments. Ein europäischer Fahrplan zur globalen Geschlechterparität bis 2050, dreizehn Abschnitte, über 70 belegte Quellen, Tempo-Rechner und Machtkarte.',
    note: 'Bewusst nicht auffindbar: unerratbare URL, noindex, nicht im Sitemap. Nicht öffentlich verlinken.',
  },
  {
    n: '04',
    title: 'Verkehr',
    url: 'verkehr.benjaminbalde.com',
    href: 'https://verkehr.benjaminbalde.com/',
    status: 'live',
    desc: 'Echtzeitkarte des öffentlichen Nahverkehrs im VRR und den angrenzenden Verbünden. Fahrzeugpositionen aus Fahrplan und Live-Verspätung rekonstruiert und zwischen den Halten interpoliert.',
    note: 'Braucht täglichen Fahrplan-Neubau, sonst leert sich die Karte.',
  },
  {
    n: '05',
    title: 'Groundwork',
    url: 'groundwork.benjaminbalde.com',
    href: 'https://groundwork.benjaminbalde.com/',
    status: 'sandbox',
    desc: 'Astro-Sandbox auf eigener Subdomain. Spielwiese für Layouts und Ideen, spiegelt das Design-System der Hauptseite, ohne die Live-Site anzufassen.',
    note: 'noindex-Testfläche, kein öffentliches Ziel.',
  },
];
---

<Base title="Verzeichnis" description="Übersicht aller Oberflächen." noindex={true}>
  <!-- HEADER -->
  <section class="section vz-head-sec">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">(∗)</span>
        <span class="sec-label">Verzeichnis</span>
      </div>
      <h1 class="display vz-title" data-reveal style="--delay:80ms">Alle Oberflächen<br />an einem Ort.</h1>
      <p class="vz-lede" data-reveal style="--delay:160ms">
        Ein Inhaltsverzeichnis für mich selbst. Diese Seite ist bewusst nicht
        gelistet und wird nicht indexiert.
      </p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- LISTE -->
  <section class="section vz-list-sec">
    <div class="shell">
      <ol class="vz-list">
        {entries.map((e, i) => (
          <li class="vz-row" data-reveal style={`--delay:${i * 70}ms`}>
            <div class="vz-idx">
              <span class="vz-n">{e.n}</span>
              <span class={`vz-badge vz-badge--${e.status}`}>{statusLabel[e.status]}</span>
              {e.langs && <span class="vz-langs">{e.langs}</span>}
            </div>
            <div class="vz-body">
              <a class="vz-link" href={e.href} target="_blank" rel="noopener">
                <span class="vz-name">{e.title}</span>
                <span class="vz-url">{e.url}<span class="vz-arrow" aria-hidden="true">↗</span></span>
              </a>
              <p class="vz-desc">{e.desc}</p>
              {e.note && <p class="vz-note">{e.note}</p>}
              {e.links && (
                <div class="vz-sublinks">
                  {e.links.map((l) => (
                    <a href={l.href} target="_blank" rel="noopener" class="vz-sublink">{l.label}</a>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .shell-rule { width: 100%; max-width: var(--maxw); margin-inline: auto; }

  .vz-head-sec { padding-bottom: clamp(2.5rem, 6vw, 4rem); }
  .vz-title {
    font-size: clamp(2.4rem, 7vw, 4.75rem);
    margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
  }
  .vz-lede {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.55;
    color: var(--muted);
    max-width: 44ch;
  }

  .vz-list-sec { padding-top: clamp(2.5rem, 6vw, 4rem); }
  .vz-list { list-style: none; }

  .vz-row {
    display: grid;
    grid-template-columns: minmax(140px, 200px) 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
    border-top: 1px solid var(--hair);
  }
  .vz-row:last-child { border-bottom: 1px solid var(--hair); }

  .vz-idx {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
    padding-top: 0.35rem;
  }
  .vz-n {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--faint);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .vz-badge {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 100px;
    border: 1px solid var(--hair-strong);
    color: var(--muted);
    white-space: nowrap;
  }
  .vz-badge--live { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 40%, var(--hair-strong)); }
  .vz-badge--hidden { color: var(--ink); border-color: var(--ink); }
  .vz-badge--sandbox { color: var(--faint); }
  .vz-langs {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--faint);
    text-transform: uppercase;
  }

  .vz-body { min-width: 0; }
  .vz-link {
    display: inline-flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    color: var(--ink);
  }
  .vz-name {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    transition: color 0.25s var(--ease);
  }
  .vz-link:hover .vz-name { color: var(--accent); }
  .vz-url {
    font-size: 0.9rem;
    color: var(--muted);
    letter-spacing: 0.01em;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }
  .vz-arrow { transition: transform 0.25s var(--ease); }
  .vz-link:hover .vz-arrow { transform: translate(2px, -2px); color: var(--accent); }

  .vz-desc {
    margin-top: 0.95rem;
    font-size: 0.97rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 58ch;
  }
  .vz-note {
    margin-top: 0.7rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--faint);
    max-width: 58ch;
    padding-left: 0.85rem;
    border-left: 2px solid var(--hair-strong);
  }

  .vz-sublinks {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.65rem;
  }
  .vz-sublink {
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-decoration: none;
    padding: 4px 11px;
    border: 1px solid var(--hair-strong);
    border-radius: 100px;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .vz-sublink:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 640px) {
    .vz-row { grid-template-columns: 1fr; gap: 0.9rem; }
    .vz-idx { flex-direction: row; align-items: center; padding-top: 0; }
  }
</style>
