---
import Base from '../layouts/Base.astro';
import data from '../data/invisible-women.json';

interface Kategorie { id: string; name: string; farbe: string; }
interface Gruppe { label: string; wert: number; }
interface Stat {
  id: string;
  kategorie: string;
  headline: string;
  kernzahl: number;
  einheit: string;
  kontext: string;
  quelle: string;
  quelle_url: string;
  visualisierung_vorschlag: 'vergleich' | 'anteil' | 'multiplikator' | 'counter';
  farbakzent: string;
  vergleich?: { gruppe_a: Gruppe; gruppe_b: Gruppe };
  anteil?: { von: number; anteil: number; label: string };
  multiplikator?: { label_basis: string; label_vergleich: string; faktor: number };
  counter?: { ziel: number; praefix?: string; format?: string };
}

const meta = data.meta;
const kategorien = data.kategorien as Kategorie[];
const statistiken = data.statistiken as Stat[];
const catById: Record<string, Kategorie> = Object.fromEntries(
  kategorien.map((k) => [k.id, k])
);

const description = `Kernstatistiken aus „${meta.buch}“ von ${meta.autorin} (${meta.jahr}), interaktiv visualisiert.`;
---

<Base title={meta.titel} description={description}>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="shell hero-shell">
      <p class="avail" data-reveal>
        <span class="dot" aria-hidden="true"></span> Datenvisualisierung
      </p>
      <h1 class="display hero-title" data-reveal>{meta.titel}</h1>
      <div class="hero-foot" data-reveal style="--delay:200ms">
        <p class="lede">{meta.untertitel}</p>
        <p class="hero-cite">
          Nach <em>{meta.buch}</em><br />
          {meta.autorin}, {meta.jahr}
        </p>
      </div>
    </div>
    <div class="hero-line" aria-hidden="true"></div>
  </section>

  <!-- ===================== FILTER + GRID ===================== -->
  <section class="section" id="daten">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">(I)</span>
        <span class="sec-label">{statistiken.length} Statistiken · {kategorien.length} Bereiche</span>
      </div>

      <div class="filters" role="tablist" aria-label="Kategorie-Filter" data-reveal>
        <button class="chip is-active" data-filter="alle" aria-pressed="true">Alle</button>
        {kategorien.map((k) => (
          <button class="chip" data-filter={k.id} aria-pressed="false" style={`--cat:${k.farbe}`}>
            <span class="chip-dot" aria-hidden="true"></span>{k.name}
          </button>
        ))}
      </div>

      <div class="grid" id="grid">
        {statistiken.map((s, i) => {
          const cat = catById[s.kategorie];
          const acc = s.farbakzent;
          return (
            <article
              class="card"
              data-category={s.kategorie}
              data-reveal
              style={`--delay:${(i % 3) * 80}ms; --acc:${acc}`}
            >
              <div class="card-tag" style={`--cat:${cat.farbe}`}>
                <span class="card-dot" aria-hidden="true"></span>{cat.name}
              </div>
              <h3 class="card-head">{s.headline}</h3>

              <div class="viz">
                {s.visualisierung_vorschlag === 'vergleich' && s.vergleich && (
                  (() => {
                    const a = s.vergleich.gruppe_a;
                    const b = s.vergleich.gruppe_b;
                    const max = Math.max(a.wert, b.wert);
                    return (
                      <div class="bars" data-viz="bars">
                        {[{ g: a, primary: true }, { g: b, primary: false }].map(({ g, primary }) => (
                          <div class="bar-row">
                            <span class="bar-label">{g.label}</span>
                            <div class="bar-track">
                              <div
                                class={`bar-fill${primary ? ' is-primary' : ''}`}
                                style={`--w:${(g.wert / max) * 100}%`}
                              ></div>
                            </div>
                            <span class="bar-val">{g.wert}</span>
                          </div>
                        ))}
                      </div>
                    );
                  })()
                )}

                {s.visualisierung_vorschlag === 'anteil' && s.anteil && (
                  <div class="anteil" data-viz="donut">
                    <svg viewBox="0 0 120 120" class="donut" role="img" aria-label={`${s.anteil.anteil} Prozent`}>
                      <circle class="donut-track" cx="60" cy="60" r="52" />
                      <circle
                        class="donut-arc"
                        cx="60" cy="60" r="52"
                        data-pct={s.anteil.anteil}
                        style="--arc:0"
                      />
                    </svg>
                    <div class="donut-center">
                      <span class="donut-num" data-count={s.anteil.anteil} data-suffix="%">0</span>
                    </div>
                    <p class="anteil-label">{s.anteil.label}</p>
                  </div>
                )}

                {s.visualisierung_vorschlag === 'multiplikator' && s.multiplikator && (
                  <div class="mult" data-viz="mult">
                    <div class="mult-big">
                      <span class="mult-num" data-count={s.multiplikator.faktor} data-suffix="×">0</span>
                    </div>
                    <div class="mult-rows">
                      <div class="mult-row">
                        <span class="mult-rl">{s.multiplikator.label_basis}</span>
                        <span class="mult-blocks"><i class="blk on" style="--bd:0ms"></i></span>
                      </div>
                      <div class="mult-row">
                        <span class="mult-rl">{s.multiplikator.label_vergleich}</span>
                        <span class="mult-blocks">
                          {Array.from({ length: s.multiplikator.faktor }).map((_, bi) => (
                            <i class="blk" style={`--bd:${bi * 90}ms`}></i>
                          ))}
                        </span>
                      </div>
                    </div>
                  </div>
                )}

                {s.visualisierung_vorschlag === 'counter' && (
                  <div class="counter" data-viz="counter">
                    {s.counter ? (
                      <span
                        class="counter-num"
                        data-count={s.counter.ziel}
                        data-prefix={s.counter.praefix ?? ''}
                        data-format="kompakt"
                      >0</span>
                    ) : (
                      <span
                        class="counter-num"
                        data-count={s.kernzahl}
                        data-suffix={` ${s.einheit}`}
                        data-decimals={Number.isInteger(s.kernzahl) ? 0 : 1}
                      >0</span>
                    )}
                  </div>
                )}
              </div>

              <p class="card-context">{s.kontext}</p>
              <a class="card-source" href={s.quelle_url} target="_blank" rel="noopener">
                <span class="src-q">Quelle:</span> {s.quelle}
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </article>
          );
        })}
      </div>

      <p class="empty" id="empty" hidden>Keine Statistiken in diesem Bereich.</p>
    </div>
  </section>

  <hr class="rule shell-rule" />

  <!-- ===================== HINWEIS ===================== -->
  <section class="section note" id="hinweis">
    <div class="shell">
      <div class="sec-head" data-reveal>
        <span class="sec-num">(II)</span>
        <span class="sec-label">Zum Datensatz</span>
      </div>
      <p class="big" data-reveal style="--delay:80ms">
        Daten, die nur den männlichen Körper als Norm kennen, sind keine neutralen Daten.
      </p>
      <p class="note-text" data-reveal style="--delay:160ms">
        Die Zahlen stammen aus <em>{meta.buch}</em> von {meta.autorin} ({meta.jahr}) und den
        jeweils verlinkten Quellen. Werte bitte vor weiterer Verwendung an der Originalquelle prüfen.
      </p>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: clamp(58vh, 70svh, 80vh);
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .hero-shell { width: 100%; }
  .avail {
    display: inline-flex; align-items: center; gap: 0.6em;
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--muted); margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--live);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--live) 60%, transparent);
    animation: pulse 2.6s infinite var(--ease);
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--live) 55%, transparent); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  .hero-title { max-width: 16ch; }
  .hero-foot {
    margin-top: clamp(2rem, 5vw, 3.25rem);
    display: flex; flex-wrap: wrap; align-items: flex-end;
    justify-content: space-between; gap: 1.5rem 2.5rem;
  }
  .hero-cite { font-size: 0.9rem; color: var(--muted); line-height: 1.5; text-align: right; }
  .hero-cite em { font-style: italic; color: var(--ink-soft); }
  .hero-line {
    position: absolute; left: var(--gutter); right: var(--gutter);
    bottom: 0; height: 1px; background: var(--hair);
  }

  /* FILTERS */
  .filters { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: clamp(2rem, 5vw, 3rem); }
  .chip {
    display: inline-flex; align-items: center; gap: 0.5em;
    font: inherit; font-size: 13px; letter-spacing: 0.01em;
    color: var(--muted); background: transparent; cursor: pointer;
    border: 1px solid var(--hair-strong); border-radius: 100px;
    padding: 0.45rem 0.95rem;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), background 0.25s var(--ease);
  }
  .chip-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--cat, var(--ink)); flex: 0 0 auto;
  }
  .chip:hover { color: var(--ink); border-color: var(--ink); }
  .chip.is-active { color: var(--paper); background: var(--ink); border-color: var(--ink); }
  .chip[data-filter]:not([data-filter='alle']).is-active {
    background: var(--cat); border-color: var(--cat);
    color: #fff;
  }
  .chip.is-active .chip-dot { background: rgba(255, 255, 255, 0.85); }

  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1px;
    background: var(--hair);
    border: 1px solid var(--hair);
  }
  .card {
    display: flex; flex-direction: column;
    background: var(--paper);
    padding: clamp(1.5rem, 3vw, 2.1rem);
    border-top: 3px solid var(--acc, var(--accent));
  }
  .card.is-hidden { display: none; }
  .card-tag {
    display: inline-flex; align-items: center; gap: 0.5em;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 0.9rem;
  }
  .card-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cat); }
  .card-head {
    font-weight: 600; font-size: 1.18rem; line-height: 1.25;
    letter-spacing: -0.015em; color: var(--ink); margin-bottom: 1.4rem;
  }
  .viz { margin-top: auto; margin-bottom: 1.4rem; }

  /* VIZ: bars */
  .bars { display: flex; flex-direction: column; gap: 0.85rem; }
  .bar-row {
    display: grid; grid-template-columns: 1fr; gap: 0.3rem;
  }
  .bar-label { font-size: 12px; color: var(--muted); }
  .bar-val {
    font-size: 12px; color: var(--faint); font-variant-numeric: tabular-nums;
    grid-row: 1; justify-self: end;
  }
  .bar-track { grid-row: 2; height: 12px; background: var(--paper-2); border-radius: 100px; overflow: hidden; }
  .bar-fill {
    height: 100%; width: 0; border-radius: 100px; background: var(--hair-strong);
    transition: width 1.1s var(--ease);
  }
  .bar-fill.is-primary { background: var(--acc); }
  [data-viz='bars'].run .bar-fill { width: var(--w); }

  /* VIZ: donut */
  .anteil { display: grid; grid-template-columns: 96px 1fr; align-items: center; gap: 1.1rem; }
  .donut { width: 96px; height: 96px; transform: rotate(-90deg); grid-row: 1; }
  .donut-track { fill: none; stroke: var(--paper-2); stroke-width: 12; }
  .donut-arc {
    fill: none; stroke: var(--acc); stroke-width: 12; stroke-linecap: round;
    stroke-dasharray: 326.7; /* 2πr, r=52 */
    stroke-dashoffset: calc(326.7 - 326.7 * var(--arc));
    transition: stroke-dashoffset 1.2s var(--ease);
  }
  .donut-center {
    grid-column: 1; grid-row: 1; align-self: center; justify-self: center;
    pointer-events: none;
  }
  .donut-num { font-size: 1.35rem; font-weight: 700; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .anteil-label { font-size: 12.5px; color: var(--muted); line-height: 1.4; }

  /* VIZ: multiplikator */
  .mult { display: flex; flex-direction: column; gap: 1rem; }
  .mult-big { line-height: 1; }
  .mult-num { font-size: clamp(2.6rem, 7vw, 3.4rem); font-weight: 800; letter-spacing: -0.04em; color: var(--acc); }
  .mult-rows { display: flex; flex-direction: column; gap: 0.6rem; }
  .mult-row { display: flex; flex-direction: column; gap: 0.3rem; }
  .mult-rl { font-size: 12px; color: var(--muted); }
  .mult-blocks { display: flex; gap: 4px; }
  .blk {
    width: 16px; height: 16px; border-radius: 3px; background: var(--paper-2);
    opacity: 0; transform: scale(0.4); transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
    transition-delay: var(--bd);
  }
  .blk.on { background: color-mix(in srgb, var(--acc) 30%, var(--paper-2)); }
  [data-viz='mult'].run .blk { opacity: 1; transform: none; }
  [data-viz='mult'].run .blk:not(.on) { background: var(--acc); }

  /* VIZ: counter */
  .counter { line-height: 1; }
  .counter-num {
    font-size: clamp(2.4rem, 6.5vw, 3.2rem); font-weight: 800;
    letter-spacing: -0.04em; color: var(--acc); font-variant-numeric: tabular-nums;
  }

  /* CARD footer */
  .card-context { font-size: 0.92rem; color: var(--muted); line-height: 1.6; margin-bottom: 1.1rem; }
  .card-source {
    margin-top: auto; font-size: 11.5px; color: var(--faint);
    text-decoration: none; line-height: 1.45;
    display: inline-flex; align-items: baseline; gap: 0.35em; flex-wrap: wrap;
    transition: color 0.25s var(--ease);
  }
  .card-source .src-q { color: var(--muted); font-weight: 500; }
  .card-source:hover { color: var(--ink); }
  .card-source .arrow { transition: transform 0.25s var(--ease); }
  .card-source:hover .arrow { transform: translate(2px, -2px); }

  .empty { padding: 3rem 0; color: var(--muted); text-align: center; }

  .shell-rule { width: 100%; max-width: var(--maxw); margin-inline: auto; }

  /* NOTE */
  .big {
    font-weight: 600; font-size: clamp(1.5rem, 3.8vw, 2.6rem);
    line-height: 1.15; letter-spacing: -0.025em; max-width: 22ch;
  }
  .note-text { margin-top: 1.5rem; color: var(--muted); font-size: 1.02rem; line-height: 1.65; max-width: 60ch; }
  .note-text em { font-style: italic; color: var(--ink-soft); }

  @media (max-width: 540px) {
    .grid { grid-template-columns: 1fr; }
    .hero-cite { text-align: left; }
  }
</style>

<script>
  const fmtCompact = new Intl.NumberFormat('de-DE', { notation: 'compact', maximumFractionDigits: 1 });
  const fmtNum = (v: number, dec: number) =>
    new Intl.NumberFormat('de-DE', { minimumFractionDigits: dec, maximumFractionDigits: dec }).format(v);

  const reduce = () =>
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function animateCount(el: HTMLElement) {
    const target = parseFloat(el.dataset.count || '0');
    const prefix = el.dataset.prefix || '';
    const suffix = el.dataset.suffix || '';
    const kompakt = el.dataset.format === 'kompakt';
    const dec = parseInt(el.dataset.decimals || '0', 10);
    const render = (v: number) => {
      const body = kompakt ? fmtCompact.format(v) : fmtNum(v, dec);
      el.textContent = `${prefix}${body}${suffix}`;
    };
    if (reduce()) { render(target); return; }
    const dur = 1400;
    let start: number | null = null;
    const step = (t: number) => {
      if (start === null) start = t;
      const p = Math.min((t - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      render(target * eased);
      if (p < 1) requestAnimationFrame(step);
      else render(target);
    };
    requestAnimationFrame(step);
  }

  function runViz(node: HTMLElement) {
    const kind = node.dataset.viz;
    if (kind === 'bars' || kind === 'mult') {
      node.classList.add('run');
    } else if (kind === 'donut') {
      const arc = node.querySelector('.donut-arc') as HTMLElement | null;
      const num = node.querySelector('.donut-num') as HTMLElement | null;
      if (arc) {
        const pct = parseFloat(arc.dataset.pct || '0') / 100;
        arc.style.setProperty('--arc', reduce() ? String(pct) : '0');
        if (!reduce()) requestAnimationFrame(() => arc.style.setProperty('--arc', String(pct)));
      }
      if (num) animateCount(num);
    } else if (kind === 'counter') {
      const num = node.querySelector('.counter-num') as HTMLElement | null;
      if (num) animateCount(num);
    }
    if (kind === 'mult') {
      const num = node.querySelector('.mult-num') as HTMLElement | null;
      if (num) animateCount(num);
    }
  }

  function setup() {
    const grid = document.getElementById('grid');
    if (!grid) return;

    const vizNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-viz]'));
    if (!('IntersectionObserver' in window) || reduce()) {
      vizNodes.forEach(runViz);
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              runViz(e.target as HTMLElement);
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.35 }
      );
      vizNodes.forEach((n) => io.observe(n));
    }

    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
    const empty = document.getElementById('empty');
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const f = chip.dataset.filter;
        chips.forEach((c) => {
          const active = c === chip;
          c.classList.toggle('is-active', active);
          c.setAttribute('aria-pressed', String(active));
        });
        let visible = 0;
        cards.forEach((card) => {
          const show = f === 'alle' || card.dataset.category === f;
          card.classList.toggle('is-hidden', !show);
          if (show) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      });
    });
  }

  document.addEventListener('astro:page-load', setup);
</script>
